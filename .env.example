NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic API key used by /cafe-writer server route (never exposed to client)
ANTHROPIC_API_KEY=sk-ant-...

# 백엔드 모드: api (기본) | local-cli
# local-cli 로 두면 ANTHROPIC_API_KEY 안 쓰고, 맥미니에 OAuth 로그인된 claude CLI 를 spawn
# 자세한 셋업: docs/mac-mini-setup.md
BACKEND_MODE=api
# CLAUDE_CODE_BIN=/usr/local/bin/claude   # claude 가 PATH 에 없을 때만 지정
